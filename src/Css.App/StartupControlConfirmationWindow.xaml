<Window x:Class="Css.App.StartupControlConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认关闭自启动"
        Width="680"
        Height="610"
        MinWidth="620"
        MinHeight="540"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.Name="确认关闭自启动窗口">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Title}"
                       FontSize="25"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>
            <TextBlock x:Name="HeadlineTextBlock"
                       AutomationProperties.AutomationId="StartupConfirmationHeadlineTextBlock"
                       Text="{Binding Headline}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1F2937"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"/>
            <TextBlock Text="{Binding Summary}"
                       Foreground="#4B5563"
                       TextWrapping="Wrap"
                       Margin="0,7,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,18,0,16">
            <StackPanel>
                <Border Background="White"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="确认后会发生什么"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <ListBox x:Name="OutcomeListBox"
                                 AutomationProperties.AutomationId="StartupConfirmationOutcomeListBox"
                                 ItemsSource="{Binding OutcomeLines}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 HorizontalContentAlignment="Stretch"
                                 Margin="0,7,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Foreground="#374151"
                                               TextWrapping="Wrap"
                                               Margin="2,4"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Text="{Binding SafetyText}"
                                   Foreground="#065F46"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="2,9,2,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Margin="0,14,0,0">
                    <CheckBox x:Name="FirstAcknowledgementCheckBox"
                              AutomationProperties.AutomationId="StartupConfirmationFirstCheckBox"
                              Foreground="#1F2937"
                              Checked="Acknowledgement_Changed"
                              Unchecked="Acknowledgement_Changed"
                              Margin="2,0,2,10">
                        <TextBlock Text="{Binding FirstAcknowledgementText}"
                                   TextWrapping="Wrap"
                                   MaxWidth="570"/>
                    </CheckBox>
                    <CheckBox x:Name="SecondAcknowledgementCheckBox"
                              AutomationProperties.AutomationId="StartupConfirmationSecondCheckBox"
                              Foreground="#1F2937"
                              Checked="Acknowledgement_Changed"
                              Unchecked="Acknowledgement_Changed"
                              Margin="2,0">
                        <TextBlock Text="{Binding SecondAcknowledgementText}"
                                   TextWrapping="Wrap"
                                   MaxWidth="570"/>
                    </CheckBox>
                </StackPanel>

                <Expander x:Name="TechnicalDetailsExpander"
                          AutomationProperties.AutomationId="StartupConfirmationTechnicalDetailsExpander"
                          Header="查看技术详情"
                          IsExpanded="False"
                          Background="White"
                          BorderBrush="#E5E7EB"
                          BorderThickness="1"
                          Padding="12"
                          Margin="0,16,0,0">
                    <ListBox ItemsSource="{Binding TechnicalDetails}"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Foreground="#374151"
                                           TextWrapping="Wrap"
                                           Margin="2,3"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="两项都确认后才能继续。取消不会修改任何设置。"
                       Foreground="#4B5563"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
            <Button x:Name="CancelButton"
                    AutomationProperties.AutomationId="StartupConfirmationCancelButton"
                    Grid.Column="1"
                    Content="取消"
                    Width="96"
                    Height="36"
                    Margin="12,0,8,0"
                    Click="Cancel_Click"/>
            <Button x:Name="ConfirmButton"
                    AutomationProperties.AutomationId="StartupConfirmationConfirmButton"
                    Grid.Column="2"
                    Content="{Binding ConfirmButtonText}"
                    Width="150"
                    Height="36"
                    IsEnabled="False"
                    Click="Confirm_Click"/>
        </Grid>
    </Grid>
</Window>
