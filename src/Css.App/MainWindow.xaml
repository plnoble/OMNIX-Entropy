<Window x:Class="Css.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OMNIX-Entropy" Height="820" Width="1280" MinHeight="720" MinWidth="1100"
        Background="#F6F7F9">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="252"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="22,24,18,20">
                    <TextBlock Text="OMNIX-Entropy" Foreground="White" FontSize="21" FontWeight="SemiBold" TextWrapping="NoWrap"/>
                    <TextBlock Text="Computer Agent" Foreground="#9CA3AF" FontSize="13" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="12,8,12,18">
                    <Button x:Name="OpenUpdateButton"
                            AutomationProperties.AutomationId="OpenUpdateButton"
                            Content="检查更新"
                            Height="38"
                            Click="OpenUpdate_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

                <StackPanel Margin="12,8">
                    <Button x:Name="HomeNavButton" AutomationProperties.AutomationId="HomeNavButton" Content="首页体检" Tag="Home" Click="Nav_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="AppsNavButton" AutomationProperties.AutomationId="AppsNavButton" Content="应用管理" Tag="Apps" Click="Nav_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="CDriveNavButton" AutomationProperties.AutomationId="CDriveNavButton" Content="C盘清理" Tag="CDrive" Click="Nav_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="InstallNavButton" AutomationProperties.AutomationId="InstallNavButton" Content="安装管控" Tag="Install" Click="Nav_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="TimelineNavButton" AutomationProperties.AutomationId="TimelineNavButton" Content="后悔药中心" Tag="Timeline" Click="Nav_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="AgentNavButton" AutomationProperties.AutomationId="AgentNavButton" Content="AI Agent" Tag="Agent" Click="Nav_Click" Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="PageTitleTextBlock" Text="首页体检" FontSize="30" FontWeight="SemiBold" Foreground="#111827"/>
                    <TextBlock x:Name="PageSubtitleTextBlock" Text="先看结论，再决定要不要处理。" Foreground="#4B5563" FontSize="14" Margin="0,7,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <ComboBox x:Name="DriveRootComboBox" Visibility="Collapsed"/>
                    <Border x:Name="DriveTargetPanel" Width="178" Height="44" Margin="0,0,8,0"
                            Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6"
                            Padding="12,6"
                            ToolTip="&#x81EA;&#x52A8;&#x8BC6;&#x522B;&#x672C;&#x673A;&#x76D8;&#x7B26;&#xFF1B;&#x9ED8;&#x8BA4;&#x4F53;&#x68C0;&#x7CFB;&#x7EDF;&#x76D8;&#x3002;">
                        <StackPanel>
                            <TextBlock x:Name="DriveTargetLabelTextBlock"
                                       Text="&#x7CFB;&#x7EDF;&#x76D8; C &#x76D8;"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                            <TextBlock x:Name="DriveTargetHintTextBlock"
                                       Text="&#x81EA;&#x52A8;&#x8BC6;&#x522B;&#xFF0C;&#x4E0D;&#x7528;&#x624B;&#x8F93;"
                                       FontSize="11"
                                       Foreground="#6B7280"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="StartScanButton" AutomationProperties.AutomationId="StartScanButton" Content="开始体检" Width="104" Height="40" Click="StartScan_Click"/>
                    <Button x:Name="CancelScanButton" Content="取消" Width="70" Height="40" Margin="8,0,0,0" Click="CancelScan_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid x:Name="HomePage">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Columns="4" Margin="0,0,0,18">
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="综合评分" Style="{StaticResource MetricTitleStyle}"/>
                                <TextBlock x:Name="OverallScoreTextBlock" Text="待体检" Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="磁盘健康" Style="{StaticResource MetricTitleStyle}"/>
                                <TextBlock x:Name="DiskHealthTextBlock" Text="待体检" Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="应用状态" Style="{StaticResource MetricTitleStyle}"/>
                                <TextBlock x:Name="AppHealthTextBlock" Text="待扫描" Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Agent 状态" Style="{StaticResource MetricTitleStyle}"/>
                                <TextBlock Text="只建议" Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="0.6*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="体检结果摘要" Style="{StaticResource SectionTitleStyle}"/>
                                <ListView x:Name="HealthDimensionListView"
                                          AutomationProperties.AutomationId="HealthDimensionListView"
                                          Margin="0,14,0,0"
                                          Height="260"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="AutomationProperties.AutomationId"
                                                    Value="{Binding Name, StringFormat=HealthDimension_{0}}"/>
                                            <Setter Property="AutomationProperties.Name"
                                                    Value="{Binding Name}"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="检测维度" Width="100">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="结果" Width="270">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Result}" TextWrapping="Wrap" Margin="0,5"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="评级" Width="85">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Rating}" TextWrapping="Wrap" Margin="0,5"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <TextBlock Text="体检历史" Style="{StaticResource SectionTitleStyle}" Margin="0,16,0,0"/>
                                <TextBlock x:Name="HealthDigestLatestHeadlineTextBlock"
                                           AutomationProperties.AutomationId="HealthDigestLatestHeadlineTextBlock"
                                           Text="还没有体检历史"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                                <TextBlock x:Name="HealthDigestLatestSummaryTextBlock"
                                           AutomationProperties.AutomationId="HealthDigestLatestSummaryTextBlock"
                                           Text="完成一次手动体检后，这里会保存摘要。"
                                           Foreground="#374151"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                                <TextBlock x:Name="HealthDigestWeeklySummaryTextBlock"
                                           AutomationProperties.AutomationId="HealthDigestWeeklySummaryTextBlock"
                                           Text="近 7 天暂无真实扫描记录。"
                                           Foreground="#374151"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                                <TextBlock x:Name="HealthDigestMonitoringNoticeTextBlock"
                                           AutomationProperties.AutomationId="HealthDigestMonitoringNoticeTextBlock"
                                           Text="当前没有后台定时扫描；只有你主动体检时才会新增记录。"
                                           Foreground="#6B7280"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                                <ListBox x:Name="HealthDigestHistoryListBox"
                                         AutomationProperties.AutomationId="HealthDigestHistoryListBox"
                                         Height="68"
                                         Margin="0,6,0,0"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="112"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" Foreground="#111827" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Summary}" Foreground="#4B5563" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Button x:Name="OpenHealthDigestEvidenceButton"
                                        AutomationProperties.AutomationId="OpenHealthDigestEvidenceButton"
                                        Content="重新体检并查看当前证据"
                                        Height="30"
                                        HorizontalAlignment="Left"
                                        Padding="12,0"
                                        Margin="0,6,0,0"
                                        IsEnabled="False"
                                        Click="OpenHealthDigestEvidence_Click"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="关键发现" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Agent &#x56DE;&#x7B54;" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,0"/>
                                <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,10,0,12">
                                    <StackPanel>
                                        <TextBlock x:Name="HomeAgentResponseTitleTextBlock"
                                                   AutomationProperties.AutomationId="HomeAgentResponseTitleTextBlock"
                                                   Text="Computer Agent"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="HomeAgentResponseBodyTextBlock"
                                                   AutomationProperties.AutomationId="HomeAgentResponseBodyTextBlock"
                                                   Text="&#x9009;&#x62E9;&#x4E00;&#x6761;&#x5173;&#x952E;&#x53D1;&#x73B0;&#xFF0C;Agent &#x4F1A;&#x5728;&#x8FD9;&#x91CC;&#x89E3;&#x91CA;&#x3002;"
                                                   Foreground="#374151"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0"/>
                                        <TextBlock x:Name="HomeAgentResponseSafetyTextBlock"
                                                   AutomationProperties.AutomationId="HomeAgentResponseSafetyTextBlock"
                                                   Text="&#x4E0D;&#x4F1A;&#x76F4;&#x63A5;&#x6267;&#x884C;&#xFF1B;&#x771F;&#x6B63;&#x52A8;&#x4F5C;&#x5FC5;&#x987B;&#x8FDB;&#x5165;&#x672C;&#x5730;&#x5B89;&#x5168;&#x7BA1;&#x7EBF;&#x3002;"
                                                   Foreground="#6B7280"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,10,0,0"/>
                                        <Button x:Name="HomeAgentResponseNavigateButton"
                                                AutomationProperties.AutomationId="HomeAgentResponseNavigateButton"
                                                Content="&#x4E0B;&#x4E00;&#x6B65;"
                                                Height="32"
                                                Padding="12,0"
                                                HorizontalAlignment="Left"
                                                Margin="0,12,0,0"
                                                Visibility="Collapsed"
                                                Click="HomeAgentResponseNavigate_Click"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="KeyFindingsEmptyStateTextBlock"
                                           AutomationProperties.AutomationId="KeyFindingsEmptyStateTextBlock"
                                           Text="完成体检后，这里会显示最值得处理的项目。"
                                           Foreground="#6B7280"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,14,0,0"/>
                                <ListBox x:Name="KeyFindingsListBox"
                                         AutomationProperties.AutomationId="KeyFindingsListBox"
                                         Margin="0,12,0,0"
                                         MinHeight="240"
                                         Visibility="Collapsed"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="0,10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Text}" FontSize="15" Foreground="#111827" TextWrapping="Wrap"/>
                                                    <WrapPanel Margin="0,8,0,0">
                                                        <Button Content="让 Agent 解释" Height="28" Padding="10,0" Tag="{Binding}" Click="ExplainHealthFinding_Click"/>
                                                        <Button Content="查看详情" Height="28" Padding="10,0" Margin="8,0,0,0" Tag="{Binding}" Click="ShowHealthFindingDetails_Click"/>
                                                        <Button Content="生成处理方案" Height="28" Padding="10,0" Margin="8,0,0,0" Tag="{Binding}" Click="CreateHealthFindingPlan_Click"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="AppsPage" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,18,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <WrapPanel VerticalAlignment="Center">
                                    <Button x:Name="AllAppsFilterButton" Content="全部应用" Tag="All" Width="78" Height="32" Margin="0,0,6,6" Click="AppFilter_Click"/>
                                    <Button x:Name="NormalAppsFilterButton" AutomationProperties.AutomationId="NormalAppsFilterButton" Content="普通应用" Tag="NormalApplications" Width="78" Height="32" Margin="0,0,6,6" Click="AppFilter_Click"/>
                                    <Button x:Name="DevelopmentAppsFilterButton" Content="开发工具" Tag="DevelopmentTools" Width="78" Height="32" Margin="0,0,6,6" Click="AppFilter_Click"/>
                                    <Button x:Name="GameAppsFilterButton" Content="游戏娱乐" Tag="GamesEntertainment" Width="78" Height="32" Margin="0,0,6,6" Click="AppFilter_Click"/>
                                    <Button x:Name="SystemAppsFilterButton" Content="系统应用" Tag="SystemApps" Width="78" Height="32" Margin="0,0,6,6" Click="AppFilter_Click"/>
                                    <Button x:Name="CDriveAppsFilterButton" Content="占 C 盘" Tag="CDrive" Width="78" Height="32" Margin="0,0,6,6" Click="AppFilter_Click"/>
                                    <Button x:Name="ResidentAppsFilterButton" Content="后台常驻" Tag="Resident" Width="78" Height="32" Margin="0,0,6,6" Click="AppFilter_Click"/>
                                    <Button x:Name="UninstallableAppsFilterButton" Content="可卸载" Tag="Uninstallable" Width="68" Height="32" Margin="0,0,6,6" Click="AppFilter_Click"/>
                                </WrapPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox x:Name="AppSortComboBox" Width="116" Height="34" SelectedIndex="0" SelectionChanged="AppSortComboBox_SelectionChanged"
                                              AutomationProperties.AutomationId="AppSortComboBox"
                                              AutomationProperties.Name="应用排序">
                                        <ComboBoxItem Content="按风险" Tag="Risk"/>
                                        <ComboBoxItem Content="按占用" Tag="Size"/>
                                        <ComboBoxItem Content="按最近安装" Tag="RecentInstall"/>
                                        <ComboBoxItem Content="按增长" Tag="RecentGrowth"/>
                                        <ComboBoxItem Content="按名称" Tag="Name"/>
                                    </ComboBox>
                                    <Grid Width="160" Height="34" Margin="8,0,0,0">
                                        <TextBox x:Name="AppSearchTextBox"
                                                 AutomationProperties.AutomationId="AppSearchTextBox"
                                                 AutomationProperties.Name="搜索应用"
                                                 VerticalContentAlignment="Center"
                                                 Padding="8,0"
                                                 TextChanged="AppSearchTextBox_TextChanged"/>
                                        <TextBlock x:Name="AppSearchPlaceholderTextBlock"
                                                   AutomationProperties.AutomationId="AppSearchPlaceholderTextBlock"
                                                   Text="搜索应用"
                                                   Foreground="#6B7280"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"
                                                   IsHitTestVisible="False"/>
                                    </Grid>
                                    <Button x:Name="ScanSoftwareButton" AutomationProperties.AutomationId="ScanSoftwareButton" Content="重新扫描" Width="92" Height="34" Margin="8,0,0,0" Click="ScanSoftware_Click"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock x:Name="AppsSummaryTextBlock" AutomationProperties.AutomationId="AppsSummaryTextBlock" Text="正在准备应用列表..."
                                       Foreground="#4B5563" TextWrapping="Wrap" Margin="0,10,0,14"/>
                        </StackPanel>

                        <ListBox x:Name="AppTilesListBox" AutomationProperties.AutomationId="AppTilesListBox" Grid.Row="1" SelectionChanged="AppTilesListBox_SelectionChanged"
                                 BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="AutomationProperties.Name" Value="{Binding AccessibilityName}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="118" Height="152" Margin="8" Padding="8" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1"
                                            AutomationProperties.Name="{Binding AccessibilityName}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Grid Width="62" Height="62" Margin="0,4,0,8">
                                                <Border Background="#F3F4F6" CornerRadius="8"/>
                                                <Border Background="{Binding IconBackground}"
                                                        CornerRadius="8"
                                                        Visibility="{Binding IconFallbackVisibility}"/>
                                                <Image Source="{Binding IconSource}"
                                                       Visibility="{Binding IconVisibility}"
                                                       Width="54"
                                                       Height="54"
                                                       Stretch="Uniform"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding IconText}"
                                                           Visibility="{Binding IconFallbackVisibility}"
                                                           FontSize="22"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <Ellipse Width="10" Height="10" Fill="{Binding StatusBrush}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Name}" Foreground="#111827" FontSize="13" TextAlignment="Center" TextWrapping="Wrap" MaxHeight="38"/>
                                            <TextBlock Text="{Binding ShortTag}" Foreground="#6B7280" FontSize="11" TextAlignment="Center" TextWrapping="Wrap" MaxHeight="28" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Border x:Name="AppDrawerPanel" Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                        <ScrollViewer x:Name="AppDrawerScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock x:Name="DrawerTitleTextBlock"
                                       AutomationProperties.AutomationId="DrawerTitleTextBlock"
                                       Text="选择一个应用"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                            <TextBlock x:Name="DrawerPublisherTextBlock" Text="点击左侧应用后，Agent 会给出结论和建议。" Style="{StaticResource BodyTextStyle}"/>
                            <TextBlock x:Name="DrawerCategorySummaryTextBlock"
                                       AutomationProperties.AutomationId="DrawerCategorySummaryTextBlock"
                                       Text="分类依据会显示在这里。"
                                       Foreground="#4B5563"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                            <Separator Margin="0,16,0,14"/>
                            <TextBlock Text="装在哪里" Style="{StaticResource MetricTitleStyle}"/>
                            <TextBlock x:Name="DrawerLocationTextBlock" Text="-" FontSize="16" Foreground="#111827" Margin="0,6,0,14" TextWrapping="Wrap"/>
                            <TextBlock Text="占多少" Style="{StaticResource MetricTitleStyle}"/>
                            <TextBlock x:Name="DrawerSizeTextBlock" Text="-" FontSize="16" Foreground="#111827" Margin="0,6,0,14" TextWrapping="Wrap"/>
                            <TextBlock Text="是否常驻" Style="{StaticResource MetricTitleStyle}"/>
                            <TextBlock x:Name="DrawerResidencyTextBlock" Text="-" FontSize="16" Foreground="#111827" Margin="0,6,0,14" TextWrapping="Wrap"/>
                            <Border Background="#F3F4F6" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Computer Agent 建议" FontWeight="SemiBold" Foreground="#111827"/>
                                    <TextBlock x:Name="DrawerAdviceTextBlock"
                                               AutomationProperties.AutomationId="DrawerAdviceTextBlock"
                                               Text="先选择应用。"
                                               Foreground="#374151"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <UniformGrid Columns="2">
                                <Button x:Name="DrawerUninstallButton" AutomationProperties.AutomationId="DrawerUninstallButton" Content="&#x5378;&#x8f7d;&#x5e72;&#x51c0;&#x70b9;" Height="34" Margin="0,0,6,8" Click="PreviewUninstall_Click"/>
                                <Button x:Name="DrawerMigrateButton" AutomationProperties.AutomationId="DrawerMigrateButton" Content="&#x8fc1;&#x79fb;&#x5230; D &#x76d8;" Height="34" Margin="6,0,0,8" Click="PreviewMigration_Click"/>
                                <Button x:Name="DrawerCleanCacheButton" AutomationProperties.AutomationId="DrawerCleanCacheButton" Content="&#x6e05;&#x7406;&#x7f13;&#x5b58;" Height="34" Margin="0,0,6,8" Click="PreviewCacheCleanup_Click"/>
                                <Button x:Name="DrawerDisableStartupButton" AutomationProperties.AutomationId="DrawerDisableStartupButton" Content="&#x7BA1;&#x7406;&#x81EA;&#x542F;&#x52A8;" Height="34" Margin="6,0,0,8" Click="PreviewStartupControl_Click"/>
                            </UniformGrid>
                            <Border x:Name="DrawerActionPreviewPanel" Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,2,0,10" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock x:Name="DrawerActionPreviewTitleTextBlock" AutomationProperties.AutomationId="DrawerActionPreviewTitleTextBlock" Text="-" Style="{StaticResource MetricTitleStyle}"/>
                                    <TextBlock x:Name="DrawerActionPreviewSummaryTextBlock" AutomationProperties.AutomationId="DrawerActionPreviewSummaryTextBlock" Text="-" Foreground="#374151" TextWrapping="Wrap" Margin="0,6,0,6"/>
                                    <TextBlock x:Name="DrawerActionPreviewAgentTextBlock" AutomationProperties.AutomationId="DrawerActionPreviewAgentTextBlock" Text="-" Foreground="#111827" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="DrawerActionPreviewNextStepTextBlock" AutomationProperties.AutomationId="DrawerActionPreviewNextStepTextBlock" Text="-" Foreground="#374151" TextWrapping="Wrap" Margin="0,5,0,0"/>
