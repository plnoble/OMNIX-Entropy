<Window x:Class="Css.App.InstallRouteMemoryChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x8BB0;&#x4F4F;&#x5B89;&#x88C5;&#x4F4D;&#x7F6E;"
        AutomationProperties.AutomationId="InstallRouteMemoryChoiceWindow"
        SizeToContent="WidthAndHeight"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F6F7F9">
    <Border Background="White"
            BorderBrush="#D1D5DB"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22">
        <StackPanel Width="460">
            <TextBlock Text="{Binding Title}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#111827"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding Summary}"
                       Foreground="#374151"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"/>
            <Border Background="#F9FAFB"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,14,0,0">
                <StackPanel>
                    <TextBlock Text="&#x5EFA;&#x8BAE;&#x4F4D;&#x7F6E;"
                               Foreground="#6B7280"
                               FontSize="12"/>
                    <TextBlock Text="{Binding RecommendedTarget}"
                               Foreground="#111827"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <TextBlock Text="{Binding SafetyText}"
                       Foreground="#6B7280"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button x:Name="CancelInstallRouteMemoryButton"
                        AutomationProperties.AutomationId="CancelInstallRouteMemoryButton"
                        Content="{Binding CancelText}"
                        Width="92"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button x:Name="RememberSoftwareRouteButton"
                        AutomationProperties.AutomationId="RememberSoftwareRouteButton"
                        Content="{Binding SoftwareOptionText}"
                        MinWidth="116"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="RememberSoftware_Click"/>
                <Button x:Name="RememberCategoryRouteButton"
                        AutomationProperties.AutomationId="RememberCategoryRouteButton"
                        Content="{Binding CategoryOptionText}"
                        MinWidth="132"
                        Height="34"
                        Click="RememberCategory_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
