<Window x:Class="Css.App.QuarantinePurgeConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认永久整理隔离区"
        Height="560"
        Width="700"
        MinHeight="500"
        MinWidth="640"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.Name="确认永久整理隔离区窗口">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Foreground="#111827" TextWrapping="Wrap"/>
            <Border Background="#FEE2E2" BorderBrush="#DC2626" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,14,0,0">
                <TextBlock x:Name="QuarantinePurgeWarningTextBlock"
                           AutomationProperties.AutomationId="QuarantinePurgeWarningTextBlock"
                           Text="{Binding Warning}"
                           Foreground="#991B1B"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,16,0,16">
            <StackPanel>
                <TextBlock x:Name="QuarantinePurgeSummaryTextBlock"
                           AutomationProperties.AutomationId="QuarantinePurgeSummaryTextBlock"
                           Text="{Binding Summary}"
                           Foreground="#374151"
                           TextWrapping="Wrap"/>
                <ListBox x:Name="QuarantinePurgeOutcomeListBox"
                         AutomationProperties.AutomationId="QuarantinePurgeOutcomeListBox"
                         ItemsSource="{Binding OutcomeLines}"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="0,10,0,0"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#374151" TextWrapping="Wrap" Margin="2,4"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Expander x:Name="QuarantinePurgeTechnicalDetailsExpander"
                          AutomationProperties.AutomationId="QuarantinePurgeTechnicalDetailsExpander"
                          Header="技术详情"
                          IsExpanded="False"
                          Background="White"
                          BorderBrush="#E5E7EB"
                          BorderThickness="1"
                          Padding="12"
                          Margin="0,12,0,0">
                    <ListBox ItemsSource="{Binding TechnicalDetails}"
                             MaxHeight="150"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" Foreground="#4B5563" TextWrapping="Wrap" Margin="2,3"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Expander>
                <CheckBox x:Name="QuarantinePurgeAcknowledgementCheckBox"
                          AutomationProperties.AutomationId="QuarantinePurgeAcknowledgementCheckBox"
                          Content="{Binding AcknowledgementText}"
                          Foreground="#7F1D1D"
                          FontWeight="SemiBold"
                          Margin="0,16,0,0"
                          Checked="Acknowledgement_Changed"
                          Unchecked="Acknowledgement_Changed"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="未勾选确认时不会执行任何删除。"
                       Foreground="#4B5563"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
            <Button x:Name="QuarantinePurgeCancelButton"
                    AutomationProperties.AutomationId="QuarantinePurgeCancelButton"
                    Grid.Column="1"
                    Content="取消"
                    Width="96"
                    Height="36"
                    Margin="12,0,8,0"
                    Click="Cancel_Click"/>
            <Button x:Name="QuarantinePurgeConfirmButton"
                    AutomationProperties.AutomationId="QuarantinePurgeConfirmButton"
                    Grid.Column="2"
                    Content="{Binding ConfirmButtonText}"
                    Width="138"
                    Height="36"
                    IsEnabled="False"
                    Click="Confirm_Click"/>
        </Grid>
    </Grid>
</Window>
