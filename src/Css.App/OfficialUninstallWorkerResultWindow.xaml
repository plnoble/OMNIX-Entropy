<Window x:Class="Css.App.OfficialUninstallWorkerResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x5B89;&#x5168;&#x64CD;&#x4F5C;&#x7ED3;&#x679C;"
        Height="430"
        Width="680"
        MinHeight="400"
        MinWidth="600"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.Name="&#x5B89;&#x5168;&#x64CD;&#x4F5C;&#x7ED3;&#x679C;&#x7A97;&#x53E3;">
    <Grid Background="#F6F7F9">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="OfficialUninstallWorkerResultTitleTextBlock"
                               AutomationProperties.AutomationId="OfficialUninstallWorkerResultTitleTextBlock"
                               Text="{Binding Title}"
                               FontSize="27"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               TextWrapping="Wrap"/>

                    <Border x:Name="OfficialUninstallWorkerResultStatusBorder"
                            HorizontalAlignment="Left"
                            Background="#FEF3C7"
                            BorderBrush="#F59E0B"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,7"
                            Margin="0,14,0,0">
                        <TextBlock x:Name="OfficialUninstallWorkerResultStatusTextBlock"
                                   AutomationProperties.AutomationId="OfficialUninstallWorkerResultStatusTextBlock"
                                   Text="{Binding StatusLabel}"
                                   Foreground="#78350F"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock x:Name="OfficialUninstallWorkerResultConclusionTextBlock"
                               AutomationProperties.AutomationId="OfficialUninstallWorkerResultConclusionTextBlock"
                               Text="{Binding Conclusion}"
                               FontSize="17"
                               Foreground="#1F2937"
                               TextWrapping="Wrap"
                               Margin="0,16,0,0"/>

                    <Border Background="#EFF6FF"
                            BorderBrush="#60A5FA"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Computer Agent &#x5EFA;&#x8BAE;"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="#1E3A8A"/>
                            <TextBlock x:Name="OfficialUninstallWorkerResultAgentAdviceTextBlock"
                                       AutomationProperties.AutomationId="OfficialUninstallWorkerResultAgentAdviceTextBlock"
                                       Text="{Binding AgentAdvice}"
                                       Foreground="#1E3A8A"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="OfficialUninstallWorkerResultSafetyTextBlock"
                               AutomationProperties.AutomationId="OfficialUninstallWorkerResultSafetyTextBlock"
                               Text="{Binding SafetyText}"
                               Foreground="#166534"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,16,0,8"/>
                </StackPanel>
            </ScrollViewer>

            <Button x:Name="OfficialUninstallWorkerResultCloseButton"
                    Grid.Row="1"
                    AutomationProperties.AutomationId="OfficialUninstallWorkerResultCloseButton"
                    Content="{Binding CloseButtonText}"
                    HorizontalAlignment="Right"
                    MinWidth="120"
                    Height="38"
                    Padding="16,0"
                    Margin="0,16,0,0"
                    IsDefault="True"
                    Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
