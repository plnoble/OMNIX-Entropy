<Window x:Class="Css.App.CleanupConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x786e;&#x8ba4;&#x6e05;&#x7406;"
        Height="520"
        Width="680"
        MinHeight="460"
        MinWidth="620"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.Name="&#x786e;&#x8ba4;&#x6e05;&#x7406;&#x7a97;&#x53e3;">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="SemiBold" Foreground="#111827" TextWrapping="Wrap"/>
            <Border Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,14,0,0">
                <TextBlock Text="&#x786e;&#x8ba4;&#x540e;&#x4e5f;&#x4e0d;&#x662f;&#x6c38;&#x4e45;&#x5220;&#x9664;&#xff1a;&#x4f1a;&#x5148;&#x8fdb;&#x9694;&#x79bb;&#x533a;&#xff0c;&#x540e;&#x6094;&#x836f;&#x4e2d;&#x5fc3;&#x4f1a;&#x7559;&#x4e0b;&#x8fd8;&#x539f;&#x8bb0;&#x5f55;&#x3002;"
                           Foreground="#78350F"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,18,0,18">
            <StackPanel>
                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Computer Agent" FontSize="17" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock x:Name="CleanupConfirmationSummaryTextBlock"
                                   AutomationProperties.AutomationId="CleanupConfirmationSummaryTextBlock"
                                   Text="{Binding BeginnerText}"
                                   Foreground="#374151"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#D1FAE5" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="CleanupConfirmationOutcomeHeaderTextBlock"
                                   AutomationProperties.AutomationId="CleanupConfirmationOutcomeHeaderTextBlock"
                                   Text="&#x786e;&#x8ba4;&#x540e;&#x4f1a;&#x53d1;&#x751f;&#x4ec0;&#x4e48;"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#065F46"/>
                        <ListBox x:Name="CleanupConfirmationOutcomeListBox"
                                 AutomationProperties.AutomationId="CleanupConfirmationOutcomeListBox"
                                 ItemsSource="{Binding OutcomePreviewLines}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Margin="0,8,0,0"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#374151" TextWrapping="Wrap" Margin="2,4"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Expander x:Name="CleanupConfirmationTechnicalDetailsExpander"
                          AutomationProperties.AutomationId="CleanupConfirmationTechnicalDetailsExpander"
                          Header="&#x6280;&#x672f;&#x8be6;&#x60c5;"
                          IsExpanded="False"
                          Background="White"
                          BorderBrush="#E5E7EB"
                          BorderThickness="1"
                          Padding="12">
                    <ListBox x:Name="CleanupConfirmationTechnicalDetailsListBox"
                             AutomationProperties.AutomationId="CleanupConfirmationTechnicalDetailsListBox"
                             ItemsSource="{Binding TechnicalDetails}"
                             MaxHeight="180"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" Foreground="#374151" TextWrapping="Wrap" Margin="2,3"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="&#x53ea;&#x6709;&#x70b9;&#x51fb;&#x786e;&#x8ba4;&#x540e;&#x624d;&#x4f1a;&#x8fdb;&#x5165;&#x672c;&#x5730;&#x5b89;&#x5168;&#x7ba1;&#x7ebf;&#x3002;"
                       Foreground="#4B5563"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
            <Button x:Name="CleanupConfirmationCancelButton"
                    AutomationProperties.AutomationId="CleanupConfirmationCancelButton"
                    Grid.Column="1"
                    Content="&#x53d6;&#x6d88;"
                    Width="96"
                    Height="36"
                    Margin="12,0,8,0"
                    Click="Cancel_Click"/>
            <Button x:Name="CleanupConfirmationConfirmButton"
                    AutomationProperties.AutomationId="CleanupConfirmationConfirmButton"
                    Grid.Column="2"
                    Content="&#x786e;&#x8ba4;&#x79fb;&#x5230;&#x9694;&#x79bb;&#x533a;"
                    Width="150"
                    Height="36"
                    Click="Confirm_Click"/>
        </Grid>
    </Grid>
</Window>
