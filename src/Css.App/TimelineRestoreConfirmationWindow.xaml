<Window x:Class="Css.App.TimelineRestoreConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认还原"
        Width="560"
        Height="350"
        MinWidth="500"
        MinHeight="320"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        AutomationProperties.Name="后悔药还原确认窗口">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Title}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>
            <TextBlock AutomationProperties.AutomationId="TimelineRestoreConfirmationHeadlineTextBlock"
                       Text="{Binding Headline}"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="#1F2937"
                       TextWrapping="Wrap"
                       Margin="0,16,0,0"/>
            <TextBlock AutomationProperties.AutomationId="TimelineRestoreConfirmationSummaryTextBlock"
                       Text="{Binding Summary}"
                       Foreground="#374151"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"/>
            <Border Background="#ECFDF5"
                    BorderBrush="#A7F3D0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,16,0,0">
                <TextBlock Text="{Binding SafetyText}"
                           Foreground="#065F46"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="只有确认后才会还原。"
                       Foreground="#6B7280"
                       VerticalAlignment="Center"/>
            <Button AutomationProperties.AutomationId="TimelineRestoreConfirmationCancelButton"
                    Grid.Column="1"
                    Content="取消"
                    Width="96"
                    Height="36"
                    Margin="12,0,8,0"
                    Click="Cancel_Click"/>
            <Button AutomationProperties.AutomationId="TimelineRestoreConfirmationConfirmButton"
                    Grid.Column="2"
                    Content="{Binding ConfirmButtonText}"
                    Width="150"
                    Height="36"
                    Click="Confirm_Click"/>
        </Grid>
    </Grid>
</Window>
