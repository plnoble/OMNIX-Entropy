<Window x:Class="Css.App.UninstallPostScanResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x5378;&#x8F7D;&#x540E;&#x68C0;&#x67E5;&#x7ED3;&#x679C;"
        Height="620"
        Width="700"
        MinHeight="560"
        MinWidth="620"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.Name="&#x5378;&#x8F7D;&#x540E;&#x68C0;&#x67E5;&#x7ED3;&#x679C;&#x7A97;&#x53E3;">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock x:Name="UninstallPostScanTitleTextBlock"
                           AutomationProperties.AutomationId="UninstallPostScanTitleTextBlock"
                           Text="{Binding Title}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           TextWrapping="Wrap"/>

                <Border x:Name="UninstallPostScanStatusBorder"
                        HorizontalAlignment="Left"
                        Background="#FEF3C7"
                        BorderBrush="#F59E0B"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,7"
                        Margin="0,14,0,0">
                    <TextBlock x:Name="UninstallPostScanStatusTextBlock"
                               AutomationProperties.AutomationId="UninstallPostScanStatusTextBlock"
                               Text="{Binding StatusLabel}"
                               Foreground="#78350F"
                               FontWeight="SemiBold"/>
                </Border>

                <TextBlock x:Name="UninstallPostScanConclusionTextBlock"
                           AutomationProperties.AutomationId="UninstallPostScanConclusionTextBlock"
                           Text="{Binding Conclusion}"
                           FontSize="17"
                           Foreground="#1F2937"
                           TextWrapping="Wrap"
                           Margin="0,16,0,0"/>

                <Border Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="&#x672C;&#x6B21;&#x53D1;&#x73B0;"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <ListBox x:Name="UninstallPostScanFactsListBox"
                                 AutomationProperties.AutomationId="UninstallPostScanFactsListBox"
                                 ItemsSource="{Binding Facts}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 IsHitTestVisible="False"
                                 Focusable="False"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Margin="0,6,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#x2022;" Foreground="#4B5563" Margin="0,0,7,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding}" Foreground="#374151" TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Background="#EFF6FF"
                        BorderBrush="#60A5FA"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Computer Agent &#x5EFA;&#x8BAE;"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#1E3A8A"/>
                        <TextBlock x:Name="UninstallPostScanAgentAdviceTextBlock"
                                   AutomationProperties.AutomationId="UninstallPostScanAgentAdviceTextBlock"
                                   Text="{Binding AgentAdvice}"
                                   Foreground="#1E3A8A"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                        <TextBlock x:Name="UninstallPostScanNextActionTextBlock"
                                   AutomationProperties.AutomationId="UninstallPostScanNextActionTextBlock"
                                   Text="{Binding PrimaryActionText, StringFormat=&#x5EFA;&#x8BAE;&#x4E0B;&#x4E00;&#x6B65;&#xFF1A;{0}}"
                                   Foreground="#111827"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="UninstallPostScanTechnicalHintTextBlock"
                           AutomationProperties.AutomationId="UninstallPostScanTechnicalHintTextBlock"
                           Text="&#x6280;&#x672F;&#x660E;&#x7EC6;&#x5DF2;&#x4FDD;&#x7559;&#xFF0C;&#x9ED8;&#x8BA4;&#x4E0D;&#x5C55;&#x793A;&#x8DEF;&#x5F84;&#x548C;&#x540E;&#x53F0;&#x6807;&#x8BC6;&#x3002;"
                           Foreground="#6B7280"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"/>

                <TextBlock x:Name="UninstallPostScanSafetyTextBlock"
                           AutomationProperties.AutomationId="UninstallPostScanSafetyTextBlock"
                           Text="&#x672C;&#x9875;&#x53EA;&#x5C55;&#x793A;&#x590D;&#x67E5;&#x7ED3;&#x8BBA;&#xFF0C;&#x4E0D;&#x4F1A;&#x7EE7;&#x7EED;&#x5220;&#x9664;&#x3001;&#x5173;&#x95ED;&#x670D;&#x52A1;&#x6216;&#x4FEE;&#x6539;&#x7CFB;&#x7EDF;&#x3002;"
                           Foreground="#166534"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,12,0,8"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="UninstallPostScanPrimaryActionButton"
                    Grid.Column="1"
                    AutomationProperties.AutomationId="UninstallPostScanPrimaryActionButton"
                    Content="{Binding PrimaryActionText}"
                    MinWidth="140"
                    Height="38"
                    Padding="16,0"
                    Margin="0,0,8,0"
                    Visibility="Collapsed"
                    Click="PrimaryAction_Click"/>
            <Button x:Name="UninstallPostScanCloseButton"
                    Grid.Column="2"
                    AutomationProperties.AutomationId="UninstallPostScanCloseButton"
                    Content="&#x6211;&#x77E5;&#x9053;&#x4E86;"
                    MinWidth="120"
                    Height="38"
                    Padding="16,0"
                    IsDefault="True"
                    Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
