<Window x:Class="Css.App.MigrationExecutionResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="迁移结果"
        Width="680"
        Height="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F7F8FA"
        AutomationProperties.Name="迁移结果窗口">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="MigrationExecutionResultTitleTextBlock"
                   AutomationProperties.AutomationId="MigrationExecutionResultTitleTextBlock"
                   Text="{Binding Title}"
                   FontSize="27"
                   FontWeight="SemiBold"
                   Foreground="#111827"
                   TextWrapping="Wrap"/>

        <Border x:Name="MigrationExecutionResultStatusBorder"
                Grid.Row="1"
                HorizontalAlignment="Left"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,5"
                Margin="0,14,0,0">
            <TextBlock x:Name="MigrationExecutionResultStatusTextBlock"
                       AutomationProperties.AutomationId="MigrationExecutionResultStatusTextBlock"
                       Text="{Binding StatusLabel}"
                       FontWeight="SemiBold"/>
        </Border>

        <TextBlock x:Name="MigrationExecutionResultConclusionTextBlock"
                   AutomationProperties.AutomationId="MigrationExecutionResultConclusionTextBlock"
                   Grid.Row="2"
                   Text="{Binding Conclusion}"
                   FontSize="16"
                   Foreground="#1F2937"
                   TextWrapping="Wrap"
                   Margin="0,16,0,0"/>

        <Border Grid.Row="3"
                Background="#EFF6FF"
                BorderBrush="#60A5FA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,18,0,0">
            <StackPanel>
                <TextBlock Text="Computer Agent 建议"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#1E3A8A"/>
                <TextBlock x:Name="MigrationExecutionResultAgentAdviceTextBlock"
                           AutomationProperties.AutomationId="MigrationExecutionResultAgentAdviceTextBlock"
                           Text="{Binding AgentAdvice}"
                           Foreground="#1E40AF"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <TextBlock x:Name="MigrationExecutionResultSafetyTextBlock"
                   AutomationProperties.AutomationId="MigrationExecutionResultSafetyTextBlock"
                   Grid.Row="4"
                   Text="{Binding SafetyText}"
                   Foreground="#166534"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Margin="0,16,0,0"/>

        <Button x:Name="MigrationExecutionResultCloseButton"
                AutomationProperties.AutomationId="MigrationExecutionResultCloseButton"
                Grid.Row="6"
                Content="{Binding CloseButtonText}"
                Width="120"
                Height="38"
                HorizontalAlignment="Right"
                Click="Close_Click"/>
    </Grid>
</Window>
