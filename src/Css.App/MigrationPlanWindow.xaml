<Window x:Class="Css.App.MigrationPlanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x8fc1;&#x79fb;&#x65b9;&#x6848;"
        Height="640"
        Width="780"
        MinHeight="540"
        MinWidth="700"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.Name="&#x8fc1;&#x79fb;&#x65b9;&#x6848;&#x7a97;&#x53e3;">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="SemiBold" Foreground="#111827"/>
            <TextBlock Text="{Binding Summary}" FontSize="15" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,8,0,0"/>
            <Border Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,16,0,0">
                <TextBlock Text="{Binding SafetyBanner}" Foreground="#78350F" FontWeight="SemiBold" TextWrapping="Wrap"/>
            </Border>
            <Border Background="#EFF6FF" BorderBrush="#60A5FA" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,10,0,0">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="MigrationPlanProductionReadinessTitleTextBlock"
                                   AutomationProperties.AutomationId="MigrationPlanProductionReadinessTitleTextBlock"
                                   FontWeight="SemiBold"
                                   Foreground="#1E3A8A"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="MigrationPlanProductionReadinessStatusTextBlock"
                                   Grid.Column="1"
                                   AutomationProperties.AutomationId="MigrationPlanProductionReadinessStatusTextBlock"
                                   Foreground="#1E40AF"
                                   FontWeight="SemiBold"
                                   Margin="12,0,0,0"/>
                    </Grid>
                    <TextBlock x:Name="MigrationPlanProductionReadinessConclusionTextBlock"
                               AutomationProperties.AutomationId="MigrationPlanProductionReadinessConclusionTextBlock"
                               Foreground="#1F2937"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                    <TextBlock x:Name="MigrationPlanProductionReadinessNextStepTextBlock"
                               AutomationProperties.AutomationId="MigrationPlanProductionReadinessNextStepTextBlock"
                               Foreground="#374151"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                    <TextBlock x:Name="MigrationPlanProductionReadinessSafetyTextBlock"
                               AutomationProperties.AutomationId="MigrationPlanProductionReadinessSafetyTextBlock"
                               Foreground="#1E3A8A"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,18,0,18">
            <StackPanel>
                <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Agent 结论" FontSize="18" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DecisionSummary.StatusLabel}"
                                       Foreground="#1D4ED8"
                                       FontWeight="SemiBold"
                                       Margin="12,0,0,0"/>
                        </Grid>
                        <TextBlock x:Name="MigrationPlanDecisionConclusionTextBlock"
                                   AutomationProperties.AutomationId="MigrationPlanDecisionConclusionTextBlock"
                                   Text="{Binding DecisionSummary.Conclusion}"
                                   Foreground="#111827"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding DecisionSummary.TargetSummary, StringFormat=放到哪里：{0}}"
                                   Foreground="#374151" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        <TextBlock x:Name="MigrationPlanDecisionNextStepTextBlock"
                                   AutomationProperties.AutomationId="MigrationPlanDecisionNextStepTextBlock"
                                   Text="{Binding DecisionSummary.NextStep, StringFormat=下一步：{0}}"
                                   Foreground="#374151" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        <TextBlock x:Name="MigrationPlanDecisionRollbackTextBlock"
                                   AutomationProperties.AutomationId="MigrationPlanDecisionRollbackTextBlock"
                                   Text="{Binding DecisionSummary.RollbackSummary, StringFormat=能否后悔：{0}}"
                                   Foreground="#374151" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding DecisionSummary.SpaceSummary}"
                                   Foreground="#374151" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Expander x:Name="MigrationPlanTechnicalDetailsExpander"
                          AutomationProperties.AutomationId="MigrationPlanTechnicalDetailsExpander"
                          Header="查看技术详情"
                          IsExpanded="False"
                          Foreground="#374151">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="{Binding DestinationLine}" Foreground="#374151" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ScoreLine}" Foreground="#374151" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding RollbackManifestLine}" Foreground="#374151" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding DestinationSpaceLine}" Foreground="#374151" TextWrapping="Wrap" Margin="0,8,0,12"/>
                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="&#x8fc1;&#x79fb;&#x51c6;&#x5907;&#x72b6;&#x6001;" FontSize="17" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock Text="{Binding PrimaryActionText, StringFormat=&#x5f53;&#x524d;&#x52a8;&#x4f5c;&#xff1a;{0}}" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,8,0,6"/>
                        <ItemsControl ItemsSource="{Binding BlockingReasons}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="&#x8fc1;&#x79fb;&#x524d;&#x68c0;&#x67e5;&#x6e05;&#x5355;" FontSize="17" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock Text="{Binding ReadinessChecklist.NextActionText}" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,8,0,8"/>
                        <ItemsControl ItemsSource="{Binding ReadinessChecklist.Steps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="165"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}" Foreground="#111827" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1" Text="{Binding StatusLabel}" Foreground="#4B5563" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="#6B7280" TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Sections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" Foreground="#111827" TextWrapping="Wrap"/>
                                        <Border Grid.Column="1" Background="#EEF2FF" CornerRadius="6" Padding="8,4" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding StatusLabel}" Foreground="#3730A3" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding Detail}" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,8,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding FinalReminder}" Foreground="#4B5563" TextWrapping="Wrap" VerticalAlignment="Center"/>
            <Button x:Name="CreateRollbackManifestButton"
                    Grid.Column="1"
                    Content="&#x751f;&#x6210;&#x56de;&#x6eda;&#x6e05;&#x5355;"
                    Width="190"
                    Height="36"
                    Margin="12,0,8,0"
                    Click="CreateRollbackManifest_Click"
                    AutomationProperties.AutomationId="MigrationCreateEvidenceButton"
                    AutomationProperties.Name="&#x751f;&#x6210;&#x56de;&#x6eda;&#x6e05;&#x5355;"/>
            <Button x:Name="RequestMigrationButton"
                    Grid.Column="2"
                    Content="&#x8bf7;&#x6c42;&#x8fc1;&#x79fb;"
                    Width="128"
                    Height="36"
                    Margin="0,0,8,0"
                    IsEnabled="False"
                    Click="RequestMigration_Click"
                    AutomationProperties.AutomationId="MigrationRequestButton"
                    AutomationProperties.Name="&#x8bf7;&#x6c42;&#x8fc1;&#x79fb;"/>
            <Button Grid.Column="3"
                    Content="&#x5173;&#x95ed;"
                    Width="96"
                    Height="36"
                    Click="Close_Click"
                    AutomationProperties.AutomationId="MigrationPlanCloseButton"/>
        </Grid>
    </Grid>
</Window>
